{
  "name": "@pheedloop/map-editor",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./editor": {
      "import": "./dist/editor.js",
      "types": "./dist/editor/index.d.ts"
    },
    "./viewer": {
      "import": "./dist/viewer.js",
      "types": "./dist/viewer/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "peerDependencies": {
    "konva": ">=10.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-konva": ">=19.0.0"
  },
  "dependencies": {
    "react-icons": "^5.6.0",
    "react-json-tree": "^0.20.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": "bash -c 'tsc -b --noEmit'"
  }
}
